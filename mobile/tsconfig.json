{
  "extends": "expo/tsconfig.base",

  "compilerOptions": {
    "moduleSuffixes": [".native", ".web", ""],
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
      // "@/*": ["./*"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
